# Database
SYNC_DATABASE_URL=postgresql+psycopg2://<db_user>:<db_password>@<db_host>:5432/<db_name>
ASYNC_DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@<db_host>:5432/<db_name>

# App / Server
FRONTEND_URL=https://your-frontend-domain.com
SERVER_IP=your.server.public.ip
DOMAIN_NAME=your-domain.com
LOG_LEVEL=INFO

# Google / Cloud
GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_CLIENT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<multiline-private-key>\n-----END PRIVATE KEY-----"
GCS_BUCKET_NAME=your-gcs-bucket-name

# Auth
JWT_SECRET_KEY=your-strong-jwt-secret
JWT_ALGORITHM=HS256

# Payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Cache / Queue
REDIS_URL=redis://your-redis-host:6379

# Email
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_NAME=YourAppName
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-password

# Vector DB
CHROMA_HOST=your-chroma-host
CHROMA_PORT=8001
