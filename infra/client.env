# Backend API URL - Used for platform subdomains (e.g., company.workzone.tech -> company.api.workzone.tech)
NEXT_PUBLIC_BACKEND_URL=https://api.workzone.tech

# Platform Domain (for subdomain detection)
# Custom domains are detected as any domain NOT ending with this
NEXT_PUBLIC_PLATFORM_DOMAIN=workzone.tech

# DNS Configuration for Custom Domains
# A Record IP - Used for both root domains and subdomains
NEXT_PUBLIC_DNS_A_RECORD_IP=35.237.10.52

# CNAME Target - Used for subdomains only
NEXT_PUBLIC_DNS_CNAME_TARGET=tenant.workzone.tech