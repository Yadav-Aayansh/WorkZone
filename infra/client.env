# Backend Configuration
NEXT_PUBLIC_BACKEND_URL=https://your-backend-domain.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Platform / Infra
NEXT_PUBLIC_PLATFORM_URL=https://your-platform-domain.com
NEXT_PUBLIC_DOMAIN_NAME=your-domain.com
NEXT_PUBLIC_GCS_BUCKET_NAME=your-gcs-bucket-name

# Site metadata (Open Graph / canonical URL)
NEXT_PUBLIC_APP_URL=https://your-platform-domain.com

# Custom-domain DNS hints shown to tenants in the dashboard (fallbacks only;
# the backend returns exact instructions per domain)
NEXT_PUBLIC_DNS_A_RECORD_IP=your.server.public.ip
NEXT_PUBLIC_DNS_CNAME_TARGET=tenant.your-domain.com

